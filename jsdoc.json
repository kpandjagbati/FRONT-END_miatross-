{
  "tags": {
    "allowUnknownTags": true,
    "dictionaries": ["jsdoc", "closure"]
  },
  "source": {
    "include": ["src"],
    "excludePattern": "(^|\\/|\\\\)\\."
  },
  "opts": {
    "encoding": "utf8",
    "destination": "./docs",
    "recurse": true,
    "readme": "./README.md",
    "template": "./node_modules/jsdoc/templates/default"
  },
  "templates": {
    "cleverLinks": false,
    "monospaceLinks": false
  }
}
